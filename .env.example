# Azure AI Search
SEARCH_ENDPOINT=https://<your-search-service>.search.windows.net
SEARCH_ADMIN_KEY=<search-admin-key>
SEARCH_QUERY_KEY=<search-query-key>

# Azure OpenAI (embeddings & chat)
AOAI_ENDPOINT=https://<your-aoai-resource>.openai.azure.com/
AOAI_KEY=<aoai-key>
AOAI_EMBED_DEPLOYMENT=text-embedding-3-large
AOAI_CHAT_DEPLOYMENT=gpt-4o

# Cohere Rerank v4.0 pro (Azure AI Foundry) — rerank sémantique de /search.
# REQUIS : /search renvoie 500 sur toute recherche si l'une manque.
# Ressource Foundry distincte, en eastus2 (seule région offrant v4.0 pro) —
# le reste de l'infra est en canadaeast.
COHERE_RERANK_ENDPOINT=https://<your-foundry-resource>.services.ai.azure.com
COHERE_RERANK_DEPLOYMENT=Cohere-rerank-v4.0-pro
COHERE_RERANK_KEY=<cohere-rerank-key>
